{
  "name": "telegram-channel-downloader",
  "version": "1.0.0",
  "description": "Scrape and download all media and messages from Telegram channels, groups, or users.",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "start:auto": "node index.js --auto",
    "rebuild-db": "node index.js rebuild-db",
    "valid": "node validators/index.js",
    "save-files": "node utils/save_files.js",
    "export-messages": "node utils/export_messages.js"
  },
  "nodemonConfig": {
    "ignore": [
      "config.json",
      "./export/*",
      "./validators/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siNeZix/telegram-channel-downloader.git"
  },
  "keywords": [
    "telegram",
    "node.js",
    "scraper"
  ],
  "author": "siNeZix",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/siNeZix/telegram-channel-downloader/issues"
  },
  "homepage": "https://github.com/siNeZix/telegram-channel-downloader#readme",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "ejs": "^3.1.10",
    "inquirer": "^8.2.6",
    "mime-db": "^1.52.0",
    "telegram": "^2.26.22"
  }
}
